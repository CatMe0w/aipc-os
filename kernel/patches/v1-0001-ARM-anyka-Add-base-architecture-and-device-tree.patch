Date: Wed, 15 Apr 2026 00:28:23 +0800
Subject: [PATCH v1 1/6] ARM: anyka: Add base architecture and device tree

---
 arch/arm/Kconfig                           |  2 +
 arch/arm/Makefile                          |  1 +
 arch/arm/boot/dts/anyka/Makefile           |  3 +
 arch/arm/boot/dts/anyka/ak7802-netbook.dts | 81 ++++++++++++++++++++++
 arch/arm/boot/dts/anyka/ak7802.dtsi        | 75 ++++++++++++++++++++
 arch/arm/mach-anyka/Kconfig                | 20 ++++++
 arch/arm/mach-anyka/Makefile               |  2 +
 arch/arm/mach-anyka/anyka.c                | 17 +++++
 8 files changed, 201 insertions(+)
 create mode 100644 arch/arm/boot/dts/anyka/Makefile
 create mode 100644 arch/arm/boot/dts/anyka/ak7802-netbook.dts
 create mode 100644 arch/arm/boot/dts/anyka/ak7802.dtsi
 create mode 100644 arch/arm/mach-anyka/Kconfig
 create mode 100644 arch/arm/mach-anyka/Makefile
 create mode 100644 arch/arm/mach-anyka/anyka.c

diff --git a/arch/arm/Kconfig b/arch/arm/Kconfig
index ec33376f8e2b..d5ca6c5afbeb 100644
--- a/arch/arm/Kconfig
+++ b/arch/arm/Kconfig
@@ -360,6 +360,8 @@ source "arch/arm/Kconfig.platforms"
 #
 source "arch/arm/mach-actions/Kconfig"
 
+source "arch/arm/mach-anyka/Kconfig"
+
 source "arch/arm/mach-alpine/Kconfig"
 
 source "arch/arm/mach-artpec/Kconfig"
diff --git a/arch/arm/Makefile b/arch/arm/Makefile
index b7de4b6b284c..8f81b7956be8 100644
--- a/arch/arm/Makefile
+++ b/arch/arm/Makefile
@@ -173,6 +173,7 @@ textofs-$(CONFIG_ARCH_AXXIA) := 0x00308000
 # Machine directory name.  This list is sorted alphanumerically
 # by CONFIG_* macro name.
 machine-$(CONFIG_ARCH_ACTIONS)		+= actions
+machine-$(CONFIG_ARCH_ANYKA)		+= anyka
 machine-$(CONFIG_ARCH_ALPINE)		+= alpine
 machine-$(CONFIG_ARCH_ARTPEC)		+= artpec
 machine-$(CONFIG_ARCH_ASPEED)           += aspeed
diff --git a/arch/arm/boot/dts/anyka/Makefile b/arch/arm/boot/dts/anyka/Makefile
new file mode 100644
index 000000000000..f13fe76accc7
--- /dev/null
+++ b/arch/arm/boot/dts/anyka/Makefile
@@ -0,0 +1,3 @@
+# SPDX-License-Identifier: GPL-2.0
+dtb-$(CONFIG_ARCH_ANYKA) += \
+	ak7802-netbook.dtb
diff --git a/arch/arm/boot/dts/anyka/ak7802-netbook.dts b/arch/arm/boot/dts/anyka/ak7802-netbook.dts
new file mode 100644
index 000000000000..cd0f1d659bd6
--- /dev/null
+++ b/arch/arm/boot/dts/anyka/ak7802-netbook.dts
@@ -0,0 +1,81 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/dts-v1/;
+
+#include <dt-bindings/gpio/gpio.h>
+#include "ak7802.dtsi"
+
+/ {
+	model = "Anyka AK7802 Netbook";
+	compatible = "anyka,ak7802-netbook", "anyka,ak7802";
+
+	aliases {
+		display0 = &framebuffer0;
+	};
+
+	chosen {
+		#address-cells = <1>;
+		#size-cells = <1>;
+		ranges;
+
+		stdout-path = "display0";
+	};
+
+	framebuffer0: framebuffer@33ed3c00 {
+		compatible = "anyka,ak7802-bootfb";
+		reg = <0x33ed3c00 0x000bb800>;
+		memory-region = <&display_reserved>;
+		width = <800>;
+		height = <480>;
+		stride = <1600>;
+		format = "r5g6b5";
+	};
+
+	memory@30000000 {
+		device_type = "memory";
+		reg = <0x30000000 0x04000000>;
+	};
+
+	reserved-memory {
+		#address-cells = <1>;
+		#size-cells = <1>;
+		ranges;
+
+		display_reserved: framebuffer@33ed3c00 {
+			reg = <0x33ed3c00 0x000bb800>;
+		};
+	};
+
+	spi_gpio: spi-gpio {
+		compatible = "spi-gpio";
+		#address-cells = <1>;
+		#size-cells = <0>;
+		num-chipselects = <1>;
+		sck-gpios = <&gpio 77 GPIO_ACTIVE_HIGH>;
+		mosi-gpios = <&gpio 78 GPIO_ACTIVE_HIGH>;
+		miso-gpios = <&gpio 79 GPIO_ACTIVE_HIGH>;
+		cs-gpios = <&gpio 84 GPIO_ACTIVE_LOW>;
+
+		ch374: ch374@0 {
+			compatible = "wch,ch37x_hcd";
+			reg = <0>;
+			spi-max-frequency = <10000000>;
+			spi-cpol;
+			spi-cpha;
+			poll-interval-ms = <250>;
+			int-gpios = <&gpio 71 GPIO_ACTIVE_LOW>;
+			/*
+			 * reset-gpios = <&gpio N GPIO_ACTIVE_LOW>;
+			 * reset-pulse-ms = <5>;
+			 * reset-settle-ms = <20>;
+			 */
+		};
+	};
+};
+
+&usb0 {
+	vbus-gpios = <&gpio 11 GPIO_ACTIVE_HIGH>;
+};
+
+&spi0 {
+	status = "disabled";
+};
diff --git a/arch/arm/boot/dts/anyka/ak7802.dtsi b/arch/arm/boot/dts/anyka/ak7802.dtsi
new file mode 100644
index 000000000000..0d3023dd9545
--- /dev/null
+++ b/arch/arm/boot/dts/anyka/ak7802.dtsi
@@ -0,0 +1,75 @@
+// SPDX-License-Identifier: GPL-2.0-only
+#include <dt-bindings/interrupt-controller/irq.h>
+
+/ {
+	compatible = "anyka,ak7802";
+	#address-cells = <1>;
+	#size-cells = <1>;
+
+	clocks {
+		xin12m: oscillator-12m {
+			compatible = "fixed-clock";
+			#clock-cells = <0>;
+			clock-frequency = <12000000>;
+		};
+	};
+
+	sysctrl: system-controller@8000000 {
+		compatible = "anyka,ak880x-sysctrl", "syscon";
+		reg = <0x8000000 0x1000>;
+	};
+
+	gpio: gpio-controller@8000074 {
+		compatible = "anyka,ak880x-gpio";
+		reg = <0x8000074 0x8c>;
+		interrupt-parent = <&sysctrl_intc>;
+		interrupts = <10>;
+		interrupt-controller;
+		#interrupt-cells = <2>;
+		gpio-controller;
+		#gpio-cells = <2>;
+		ngpios = <117>;
+	};
+
+	main_intc: interrupt-controller@8000000 {
+		compatible = "anyka,ak880x-intc";
+		reg = <0x8000000 0x1000>;
+		interrupt-controller;
+		#interrupt-cells = <1>;
+	};
+
+	sysctrl_intc: interrupt-controller@800004c {
+		compatible = "anyka,ak880x-sysctrl-intc";
+		reg = <0x8000000 0x1000>;
+		interrupt-parent = <&main_intc>;
+		interrupts = <27>;
+		interrupt-controller;
+		#interrupt-cells = <1>;
+	};
+
+	timer@80000018 {
+		compatible = "anyka,ak880x-timer";
+		reg = <0x8000018 0x08>;
+		interrupt-parent = <&sysctrl_intc>;
+		interrupts = <5>, <4>;
+		clocks = <&xin12m>;
+	};
+
+	spi0: spi@20024000 {
+		compatible = "anyka,ak880x-spi";
+		reg = <0x20024000 0x24>;
+		syscon = <&sysctrl>;
+		#address-cells = <1>;
+		#size-cells = <0>;
+		status = "disabled";
+	};
+
+	usb0: usb@70000000 {
+		compatible = "anyka,ak98-fshc";
+		reg = <0x70000000 0x1000>;
+		interrupt-parent = <&main_intc>;
+		interrupts = <23>;
+		syscon = <&sysctrl>;
+		status = "okay";
+	};
+};
diff --git a/arch/arm/mach-anyka/Kconfig b/arch/arm/mach-anyka/Kconfig
new file mode 100644
index 000000000000..428c6e21b974
--- /dev/null
+++ b/arch/arm/mach-anyka/Kconfig
@@ -0,0 +1,20 @@
+# SPDX-License-Identifier: GPL-2.0-only
+
+menuconfig ARCH_ANYKA
+	bool "Anyka AK78/AK88/AK98 SoC support"
+	depends on ARCH_MULTI_V5
+	depends on CPU_LITTLE_ENDIAN
+	select COMMON_CLK
+	select CPU_ARM926T
+	select GENERIC_IRQ_CHIP
+	select GPIO_ANYKA
+	select GPIOLIB
+	select IRQ_DOMAIN
+	select MFD_SYSCON
+	select SPI
+	select USE_OF
+	help
+	  Support for the Anyka ARM926-based AK78/AK88/AK98 family.
+
+	  This enables a DT-only machine entry together with the Anyka
+	  interrupt controller and timer drivers.
diff --git a/arch/arm/mach-anyka/Makefile b/arch/arm/mach-anyka/Makefile
new file mode 100644
index 000000000000..4c1f0d88e5d7
--- /dev/null
+++ b/arch/arm/mach-anyka/Makefile
@@ -0,0 +1,2 @@
+# SPDX-License-Identifier: GPL-2.0-only
+obj-$(CONFIG_ARCH_ANYKA) += anyka.o
diff --git a/arch/arm/mach-anyka/anyka.c b/arch/arm/mach-anyka/anyka.c
new file mode 100644
index 000000000000..b569d8dcea18
--- /dev/null
+++ b/arch/arm/mach-anyka/anyka.c
@@ -0,0 +1,17 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Support for Anyka ARM926 SoCs
+ *
+ * Copyright (C) 2026 CatMe0w
+ */
+
+#include <asm/mach/arch.h>
+
+static const char *const anyka_dt_compat[] __initconst = {
+	"anyka,ak7802",
+	NULL,
+};
+
+DT_MACHINE_START(ANYKA_DT, "Anyka SoC (Flattened Device Tree)")
+	.dt_compat = anyka_dt_compat,
+MACHINE_END
