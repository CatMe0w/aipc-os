+			fsh_index_readb(i, NAK_TO_EP0), fsh_index_readb(i, RX_EP_TYPE), fsh_index_readb(i, TX_EP_TYPE),
+			fsh_index_readw(i, MaxPackSz_TX), fsh_index_readw(i, MaxPackSz_RX),
