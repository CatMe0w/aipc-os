diff --git a/drivers/spi/spi-ak88-test.c b/drivers/spi/spi-ak88-test.c
new file mode 100644
index 000000000000..d06f179f08ce
--- /dev/null
+++ b/drivers/spi/spi-ak88-test.c
@@ -0,0 +1,59 @@
+// SPDX-License-Identifier: GPL-2.0-only
+
+#include <kunit/test.h>
+#include <linux/bitops.h>
+#include <linux/spi/spi.h>
+
+#define AK88_SPICON_CS_FORCE	BIT(5)
+#define AK88_SPICON_CPHA	BIT(3)
+#define AK88_SPICON_CPOL	BIT(2)
+#define AK88_SPICON_ARRM	BIT(1)
+#define AK88_SPICON_TGDM	BIT(0)
+
+extern u32 ak88_spi_build_ctrl(u32 ctrl, u32 mode, bool tx, bool rx);
+
+static void ak88_spi_ctrl_preserves_cs_for_duplex(struct kunit *test)
+{
+	u32 ctrl = ak88_spi_build_ctrl(AK88_SPICON_CS_FORCE, 0, true, true);
+
+	KUNIT_EXPECT_TRUE(test, ctrl & AK88_SPICON_CS_FORCE);
+	KUNIT_EXPECT_FALSE(test, ctrl & AK88_SPICON_ARRM);
+	KUNIT_EXPECT_FALSE(test, ctrl & AK88_SPICON_TGDM);
+}
+
+static void ak88_spi_ctrl_selects_write_only_mode(struct kunit *test)
+{
+	u32 ctrl = ak88_spi_build_ctrl(0, SPI_CPOL, true, false);
+
+	KUNIT_EXPECT_TRUE(test, ctrl & AK88_SPICON_ARRM);
+	KUNIT_EXPECT_FALSE(test, ctrl & AK88_SPICON_TGDM);
+	KUNIT_EXPECT_TRUE(test, ctrl & AK88_SPICON_CPOL);
+	KUNIT_EXPECT_FALSE(test, ctrl & AK88_SPICON_CPHA);
+}
+
+static void ak88_spi_ctrl_selects_read_only_mode(struct kunit *test)
+{
+	u32 ctrl = ak88_spi_build_ctrl(0, SPI_CPHA, false, true);
+
+	KUNIT_EXPECT_FALSE(test, ctrl & AK88_SPICON_ARRM);
+	KUNIT_EXPECT_TRUE(test, ctrl & AK88_SPICON_TGDM);
+	KUNIT_EXPECT_TRUE(test, ctrl & AK88_SPICON_CPHA);
+	KUNIT_EXPECT_FALSE(test, ctrl & AK88_SPICON_CPOL);
+}
+
+static struct kunit_case ak88_spi_test_cases[] = {
+	KUNIT_CASE(ak88_spi_ctrl_preserves_cs_for_duplex),
+	KUNIT_CASE(ak88_spi_ctrl_selects_write_only_mode),
+	KUNIT_CASE(ak88_spi_ctrl_selects_read_only_mode),
+	{}
+};
+
+static struct kunit_suite ak88_spi_test_suite = {
+	.name = "spi-ak88-test",
+	.test_cases = ak88_spi_test_cases,
+};
+
+kunit_test_suite(ak88_spi_test_suite);
+
+MODULE_DESCRIPTION("KUnit tests for Anyka AK88 SPI controller");
+MODULE_LICENSE("GPL");
diff --git a/drivers/spi/spi-ak88.c b/drivers/spi/spi-ak88.c
new file mode 100644
index 000000000000..f79b1c2a919c
--- /dev/null
+++ b/drivers/spi/spi-ak88.c
@@ -0,0 +1,333 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * Minimal SPI master support for Anyka AK78/AK88/AK98 SoCs.
+ *
+ * This first slice is intentionally small: polling only, 8-bit transfers
+ * only, and just enough controller support to reach the board's CH374U.
+ * 
+ * Copyright (C) 2026 CatMe0w
+ * Based on vendor kernel code provided by:
+ * Copyright (C) 2001-2010 ANYKA LTD.
+ */
+
+#include <linux/bitops.h>
+#include <linux/kernel.h>
+#include <linux/io.h>
+#include <linux/iopoll.h>
+#include <linux/mfd/syscon.h>
+#include <linux/module.h>
+#include <linux/of.h>
+#include <linux/of_device.h>
+#include <linux/platform_device.h>
+#include <linux/regmap.h>
+#include <linux/spi/spi.h>
+
+#define AK88_SPICON			0x00
+#define AK88_SPICON_EN			BIT(6)
+#define AK88_SPICON_CS_FORCE		BIT(5)
+#define AK88_SPICON_MS			BIT(4)
+#define AK88_SPICON_CPHA		BIT(3)
+#define AK88_SPICON_CPOL		BIT(2)
+#define AK88_SPICON_ARRM		BIT(1)
+#define AK88_SPICON_TGDM		BIT(0)
+
+#define AK88_SPISTA			0x04
+#define AK88_SPISTA_MPROC		BIT(9)
+#define AK88_SPISTA_TRANSF		BIT(8)
+#define AK88_SPISTA_TXHEMP		BIT(2)
+
+#define AK88_SPICNT			0x0c
+#define AK88_SPIOUT			0x18
+#define AK88_SPIIN			0x1c
+
+#define AK88_CLOCK_CTRL_REG		0x0c
+#define AK88_CLOCK_CTRL_SPI		BIT(2)
+#define AK88_SHAREPIN_CON1		0x78
+#define AK88_SHAREPIN_SPI0		BIT(30)
+#define AK88_PPU_PPD3			0xa4
+#define AK88_SPI0_GPIO_MASK		GENMASK(15, 12)
+
+#define AK88_SPI_INPUT_CLOCK_HZ		124000000
+#define AK88_DEFAULT_DIV		(0x7f << 8)
+#define AK88_XFER_TIMEOUT_US		10000
+
+struct ak88_spi {
+	void __iomem *base;
+	struct regmap *sysctrl;
+};
+
+static int ak88_spi_enable_clock(struct ak88_spi *hw)
+{
+	/*
+	 * The vendor 2.6 driver explicitly enables spi_clk, which clears
+	 * CLK_CON bit 2 on AK78/AK88/AK98 parts.
+	 */
+	return regmap_update_bits(hw->sysctrl, AK88_CLOCK_CTRL_REG,
+				  AK88_CLOCK_CTRL_SPI, 0);
+}
+
+static int ak88_spi_config_pins(struct ak88_spi *hw)
+{
+	int ret;
+
+	/*
+	 * AK7802 SPI pins are shared with GPIO[76:79] and require function mux.
+	 */
+	ret = regmap_update_bits(hw->sysctrl, AK88_SHAREPIN_CON1,
+				 AK88_SHAREPIN_SPI0, AK88_SHAREPIN_SPI0);
+	if (ret)
+		return ret;
+
+	/*
+	 * Datasheet default keeps pull-up/down enabled; disable it for SPI pins
+	 * so DIN is not biased low when the peripheral drives MISO.
+	 */
+	ret = regmap_update_bits(hw->sysctrl, AK88_PPU_PPD3,
+				 AK88_SPI0_GPIO_MASK, AK88_SPI0_GPIO_MASK);
+	if (ret)
+		return ret;
+
+	return 0;
+}
+
+static void ak88_spi_set_speed(struct ak88_spi *hw, u32 speed_hz)
+{
+	u32 ctrl;
+	u32 div;
+
+	if (!speed_hz)
+		return;
+
+	div = DIV_ROUND_UP(AK88_SPI_INPUT_CLOCK_HZ, speed_hz * 2);
+	if (!div)
+		div = 1;
+	if (div > 128)
+		div = 128;
+
+	ctrl = readl(hw->base + AK88_SPICON);
+	ctrl &= ~AK88_DEFAULT_DIV;
+	ctrl |= (div - 1) << 8;
+	writel(ctrl, hw->base + AK88_SPICON);
+}
+
+u32 ak88_spi_build_ctrl(u32 ctrl, u32 mode, bool tx, bool rx);
+
+u32 ak88_spi_build_ctrl(u32 ctrl, u32 mode, bool tx, bool rx)
+{
+	ctrl &= AK88_SPICON_CS_FORCE | AK88_DEFAULT_DIV;
+
+	ctrl |= AK88_SPICON_EN | AK88_SPICON_MS;
+
+	if (mode & SPI_CPHA)
+		ctrl |= AK88_SPICON_CPHA;
+	if (mode & SPI_CPOL)
+		ctrl |= AK88_SPICON_CPOL;
+
+	if (tx && !rx)
+		ctrl |= AK88_SPICON_ARRM;
+	else if (!tx && rx)
+		ctrl |= AK88_SPICON_TGDM;
+
+	return ctrl;
+}
+EXPORT_SYMBOL_GPL(ak88_spi_build_ctrl);
+
+static void ak88_spi_program_mode(struct ak88_spi *hw, u32 mode, bool tx, bool rx)
+{
+	u32 ctrl = readl(hw->base + AK88_SPICON);
+
+	ctrl = ak88_spi_build_ctrl(ctrl, mode, tx, rx);
+
+	writel(ctrl, hw->base + AK88_SPICON);
+}
+
+static int ak88_spi_wait_tx_empty(struct ak88_spi *hw)
+{
+	u32 val;
+
+	return readl_poll_timeout(hw->base + AK88_SPISTA, val,
+				  val & AK88_SPISTA_TXHEMP, 1,
+				  AK88_XFER_TIMEOUT_US);
+}
+
+static int ak88_spi_wait_done(struct ak88_spi *hw)
+{
+	u32 val;
+
+	return readl_poll_timeout(hw->base + AK88_SPISTA, val,
+				  !(val & AK88_SPISTA_MPROC), 1,
+				  AK88_XFER_TIMEOUT_US);
+}
+
+static int ak88_spi_xfer_byte(struct ak88_spi *hw, bool tx_en, bool rx_en,
+			      u8 tx, u8 *rx)
+{
+	int ret;
+
+	writel(1, hw->base + AK88_SPICNT);
+
+	ret = ak88_spi_wait_tx_empty(hw);
+	if (ret)
+		return ret;
+
+	writel(tx_en ? tx : 0xff, hw->base + AK88_SPIOUT);
+
+	ret = ak88_spi_wait_done(hw);
+	if (ret)
+		return ret;
+
+	if (rx_en && rx)
+		*rx = readl(hw->base + AK88_SPIIN);
+
+	return 0;
+}
+
+static int ak88_spi_transfer_one(struct spi_controller *ctlr,
+				 struct spi_device *spi,
+				 struct spi_transfer *xfer)
+{
+	struct ak88_spi *hw = spi_controller_get_devdata(ctlr);
+	const u8 *tx = xfer->tx_buf;
+	u8 *rx = xfer->rx_buf;
+	u32 speed_hz = xfer->speed_hz ? xfer->speed_hz : spi->max_speed_hz;
+	unsigned int i;
+	int ret;
+
+	if (xfer->bits_per_word && xfer->bits_per_word != 8)
+		return -EINVAL;
+
+	ak88_spi_set_speed(hw, speed_hz);
+	ak88_spi_program_mode(hw, spi->mode, !!tx, !!rx);
+
+	for (i = 0; i < xfer->len; i++) {
+		u8 value = tx ? tx[i] : 0xff;
+		u8 data;
+
+		ret = ak88_spi_xfer_byte(hw, !!tx, !!rx, value, &data);
+		if (ret) {
+			dev_err(&spi->dev,
+				"byte transfer timed out at offset %u\n", i);
+			return ret;
+		}
+
+		if (rx)
+			rx[i] = data;
+	}
+
+	return 0;
+}
+
+static void ak88_spi_set_cs(struct spi_device *spi, bool level)
+{
+	struct ak88_spi *hw = spi_controller_get_devdata(spi->controller);
+	u32 ctrl = readl(hw->base + AK88_SPICON);
+
+	/*
+	 * The SPI core passes the physical chip-select line level after
+	 * applying SPI_CS_HIGH policy. AK88 SPICON bit5 polarity differs across
+	 * vendor docs/ports; keep this mapping to drive requested line level.
+	 */
+	if (level)
+		ctrl |= AK88_SPICON_CS_FORCE;
+	else
+		ctrl &= ~AK88_SPICON_CS_FORCE;
+
+	writel(ctrl, hw->base + AK88_SPICON);
+}
+
+static int ak88_spi_setup(struct spi_device *spi)
+{
+	if (!spi->bits_per_word)
+		spi->bits_per_word = 8;
+
+	if (spi->bits_per_word != 8)
+		return -EINVAL;
+
+	if (spi->mode & ~(SPI_CPOL | SPI_CPHA | SPI_CS_HIGH))
+		return -EINVAL;
+
+	return 0;
+}
+
+static int ak88_spi_probe(struct platform_device *pdev)
+{
+	struct spi_controller *ctlr;
+	struct ak88_spi *hw;
+	bool keep_preinit_state;
+	u32 sharepin;
+	int ret;
+
+	ctlr = devm_spi_alloc_host(&pdev->dev, sizeof(*hw));
+	if (!ctlr)
+		return -ENOMEM;
+
+	hw = spi_controller_get_devdata(ctlr);
+
+	hw->base = devm_platform_ioremap_resource(pdev, 0);
+	if (IS_ERR(hw->base))
+		return PTR_ERR(hw->base);
+
+	hw->sysctrl = syscon_regmap_lookup_by_phandle(pdev->dev.of_node, "syscon");
+	if (IS_ERR(hw->sysctrl))
+		return dev_err_probe(&pdev->dev, PTR_ERR(hw->sysctrl),
+				     "failed to map sysctrl\n");
+
+	keep_preinit_state = device_property_read_bool(&pdev->dev,
+						      "anyka,keep-preinit-state");
+
+	ret = ak88_spi_enable_clock(hw);
+	if (ret)
+		return dev_err_probe(&pdev->dev, ret,
+				     "failed to enable SPI clock\n");
+
+	if (!keep_preinit_state) {
+		ret = ak88_spi_config_pins(hw);
+		if (ret)
+			return dev_err_probe(&pdev->dev, ret,
+					     "failed to configure SPI pins\n");
+	} else {
+		dev_info(&pdev->dev,
+			 "keeping preinit pin state (HaRET/bootloader configured)\n");
+	}
+
+	ret = regmap_read(hw->sysctrl, AK88_SHAREPIN_CON1, &sharepin);
+	if (!ret)
+		dev_info(&pdev->dev,
+			 "sharepin_con1=0x%08x spi_mux_bit30=%u\n",
+			 sharepin, !!(sharepin & AK88_SHAREPIN_SPI0));
+
+	ctlr->mode_bits = SPI_CPOL | SPI_CPHA | SPI_CS_HIGH;
+	ctlr->bits_per_word_mask = SPI_BPW_MASK(8);
+	ctlr->num_chipselect = 1;
+	ctlr->setup = ak88_spi_setup;
+	ctlr->set_cs = ak88_spi_set_cs;
+	ctlr->transfer_one = ak88_spi_transfer_one;
+	ctlr->dev.of_node = pdev->dev.of_node;
+
+	platform_set_drvdata(pdev, ctlr);
+
+	ak88_spi_set_speed(hw, 1000000);
+	ak88_spi_program_mode(hw, 0, true, true);
+
+	dev_info(&pdev->dev, "Anyka SPI controller ready\n");
+
+	return devm_spi_register_controller(&pdev->dev, ctlr);
+}
+
+static const struct of_device_id ak88_spi_of_match[] = {
+	{ .compatible = "anyka,ak880x-spi" },
+	{ }
+};
+MODULE_DEVICE_TABLE(of, ak88_spi_of_match);
+
+static struct platform_driver ak88_spi_driver = {
+	.probe = ak88_spi_probe,
+	.driver = {
+		.name = "ak88-spi",
+		.of_match_table = ak88_spi_of_match,
+	},
+};
+module_platform_driver(ak88_spi_driver);
+
+MODULE_DESCRIPTION("Anyka AK88/98 minimal SPI master");
+MODULE_LICENSE("GPL");
