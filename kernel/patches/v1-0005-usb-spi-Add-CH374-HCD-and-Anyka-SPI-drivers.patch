+static int Write374Byte(struct usb_hcd *hcd, unsigned char mAddr, unsigned char mData)
+{
+	struct ch37x_hcd_data *ch37x_hcd = hcd_to_ch37x(hcd);
+	struct spi_device *spi = to_spi_device(hcd->self.controller);
+
+	unsigned char header[2];
+	unsigned char txbuf[1];
+	int ret;
+	header[0] = mAddr;
+	header[1] = CMD_SPI_374WRITE;
+	txbuf[0] = mData;
+
+	ret = ch37x_spi_header_then_data(spi, header, ARRAY_SIZE(header),
+					 txbuf, NULL, ARRAY_SIZE(txbuf));
+	ch37x_hcd_dbg_data(ch37x_hcd, "%s:tx:0x%02x,0x%02x,0x%02x\n",
+			   __func__, header[0], header[1], txbuf[0]);
+	if (ret)
+		dev_err(&spi->dev, "%s: reg 0x%02x write 0x%02x failed: %d\n", __func__, mAddr, mData, ret);
+
+	return ret;
+}
+
+static unsigned char Read374Byte(struct usb_hcd *hcd, unsigned char mAddr)
+{
+	struct ch37x_hcd_data *ch37x_hcd = hcd_to_ch37x(hcd);
+	struct spi_device *spi = to_spi_device(hcd->self.controller);
+
+	unsigned char header[2];
+	unsigned char rxbuf[1] = { 0 };
+	int ret;
+
+	header[0] = mAddr;
+	header[1] = CMD_SPI_374READ;
+
+	ret = ch37x_spi_header_then_data(spi, header, ARRAY_SIZE(header),
+					 NULL, rxbuf, ARRAY_SIZE(rxbuf));
+	if (ret)
+		dev_err(&spi->dev, "%s: reg 0x%02x read failed: %d\n", __func__, mAddr, ret);
+
+	ch37x_hcd_dbg_data(ch37x_hcd, "%s:tx:0x%02x,0x%02x, rx:0x%02x\n",
+			   __func__, header[0], header[1], rxbuf[0]);
+
+	return rxbuf[0];
+}
